# ==========================================================
# Supabase
# ==========================================================
# Project URL (untuk API/Auth jika dibutuhkan)
SUPABASE_URL=

# Anon/publishable key (biasanya dipakai FE / client-side)
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Direct/pooled Postgres connection string (DIPAKAI oleh backend ini)
# Contoh:
# postgresql://postgres.gnqyzqbutalrygulppty:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
SUPABASE_CONNECTION_STRING=

# JWT secret dari Supabase project settings (dibutuhkan untuk validasi Bearer token)
SUPABASE_JWT_SECRET=

# Opsional: validasi issuer/audience
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=

# Service role key (DIPAKAI oleh backend untuk bypass RLS storage)
SUPABASE_SERVICE_ROLE_KEY=

# ==========================================================
# CORS (optional)
# ==========================================================
# Comma-separated origins. Example: http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=
